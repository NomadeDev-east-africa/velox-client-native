<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Réseau (Firebase / cartes / API) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Localisation (taxi / livraison) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notifications push (FCM) — requis à partir d'Android 13 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".VeloxApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo_velox_bg"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_velox_bg"
        android:supportsRtl="true"
        android:theme="@style/Theme.Velox_client">

        <!-- Icône/couleur/canal par défaut des notifications FCM (utilisés quand l'OS
             affiche lui-même la notif en arrière-plan/app tuée). Logo Velox partout. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/logo_velox_bg" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/velox_green" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="velox_default" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Velox_client">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Réception des push FCM -->
        <service
            android:name=".core.notifications.VeloxMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Persiste la langue choisie via AppCompatDelegate.setApplicationLocales -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

    </application>

</manifest>
